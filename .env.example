# MCM/ICM Award Predictor — 环境变量配置
# 复制此文件为 .env 并填入真实值（.env 不会被提交到 Git）

# === 必填 ===
# DeepSeek API Key (从 https://platform.deepseek.com 获取)
DEEPSEEK_API_KEY=sk-your-key-here

# === 生产环境必填 ===
# 允许访问的域名（Render 上设为你的 *.onrender.com 域名）
ALLOWED_HOSTS=your-app.onrender.com,www.your-domain.com

# === 推荐开启 ===
# 信任反向代理头（Render/Fly.io/Nginx 等平台必须设为 1）
TRUST_PROXY_HEADERS=1
# 强制 HTTPS（生产环境推荐）
REQUIRE_HTTPS=1

# === DeepSeek 模型配置（可选） ===
# 模型名称（默认 deepseek-v4-flash）
DEEPSEEK_MODEL=deepseek-v4-flash
# API 地址（默认 DeepSeek 官方）
DEEPSEEK_BASE_URL=https://api.deepseek.com
# 最大输出 token 数
DEEPSEEK_MAX_TOKENS=1500
# API 超时秒数
DEEPSEEK_TIMEOUT=45

# === 评分开关（可选） ===
# 设为 0/false/no 可禁用 AI 评分
LLM_RUBRIC_ENABLED=1

# === 运行端口（可选，Render 自动设置 PORT） ===
# PORT=8000
